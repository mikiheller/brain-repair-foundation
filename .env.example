# Contact form delivery
# Used by app/api/contact/route.ts via Resend (https://resend.com)
RESEND_API_KEY=

# Address that receives contact submissions
CONTACT_TO_EMAIL=hello@brainrepairfoundation.org

# Verified sender domain in Resend (must be a domain you control)
CONTACT_FROM_EMAIL=contact@brainrepairfoundation.org

# Site URL used in metadata / Open Graph
NEXT_PUBLIC_SITE_URL=https://brainrepairfoundation.org
