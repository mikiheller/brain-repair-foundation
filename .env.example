# Lab access request form delivery
# Used by app/api/lab-access/route.ts via Resend (https://resend.com)
RESEND_API_KEY=

# Address that receives request submissions
LAB_REQUEST_TO_EMAIL=hello@brainrepairfoundation.org

# Verified sender domain in Resend (must be a domain you control)
LAB_REQUEST_FROM_EMAIL=requests@brainrepairfoundation.org

# Site URL used in metadata / Open Graph
NEXT_PUBLIC_SITE_URL=https://brainrepairfoundation.org
